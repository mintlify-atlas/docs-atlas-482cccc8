  "keyFeatures": [
    "Voice notifications using game character sound packs",
    "Visual overlay notifications on all screens",
    "165+ sound packs from Warcraft, StarCraft, Portal, Zelda, and more",
    "Multi-IDE support via adapters (Claude Code, Cursor, OpenCode, Amp, etc.)",
    "Remote development support via audio relay (SSH, devcontainers, Codespaces)",
    "Mobile push notifications",
    "MCP server for AI agent sound selection",
    "Peon Trainer for exercise reminders during coding sessions",
    "Configurable pack rotation and per-project pack binding",
    "CESP v1.0 compliant (Coding Event Sound Pack Specification)"
  ],
  "publicApiSurface": [
    "peon toggle",
